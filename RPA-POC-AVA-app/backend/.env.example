FLASK_ENV=development
FLASK_DEBUG=1
MAX_CONTENT_LENGTH=10485760
UPLOAD_FOLDER=uploads

# Backend URL Configuration
# Used for absolute image paths in validation display
# For localhost: http://localhost:5000
# For production: https://your-production-domain.com (or your actual server URL)
BACKEND_URL=http://localhost:5000

# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://your-endpoint.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4

# Session Management
SESSION_STORAGE_PATH=data/sessions.json
SESSION_TIMEOUT_HOURS=4

# File Upload Configuration
TEMP_UPLOAD_PATH=data/uploads/
MAX_FILE_SIZE=10485760

# Database Configuration
# Set to 'true' to use SQL Server, 'false' to use JSON mock data
USE_SQL_SERVER=false
DB_SERVER=your-sql-server-hostname
DB_NAME=your-database-name
DB_USER=your-username
DB_PASSWORD=your-password
DB_DRIVER=ODBC Driver 17 for SQL Server
