# Example env file for manual / local runs of deploy-prod.ps1 on an IIS server.
#
# Usage:
#   1. Copy this file to deploy/iis/local.env
#   2. Fill in the values below
#   3. Run:  .\deploy-prod.ps1
#      (or:  .\deploy-prod.ps1 -EnvFile path\to\some-other.env)
#
# Format: bash-style `NAME=value`. Lines starting with `#` and blank lines are
# ignored. Optional surrounding double or single quotes are stripped.
#
# SECURITY: local.env contains secrets. It is .gitignore'd at the repo root —
# never commit it. Under Octopus, the equivalent values come from the project
# variable set (Octopus handles secret storage) and this file is not used.
# -----------------------------------------------------------------------------

# Public hostname the frontend site binds to. Must match the SAN on the cert
# referenced by CERT_THUMBPRINT below.
SITE_HOSTNAME=rpa-poc.example.gov

# Thumbprint of the HTTPS cert already imported into LocalMachine\My.
# Get it with: Get-ChildItem Cert:\LocalMachine\My | Format-Table Thumbprint, Subject
CERT_THUMBPRINT=A1B2C3D4E5F6A1B2C3D4E5F6A1B2C3D4E5F6A1B2

# Physical path the deployed app lives at. <DEPLOY_ROOT>.previous holds the
# rollback snapshot.
DEPLOY_ROOT=C:\inetpub\HRSA-RPA-POC

# Loopback port the backend site binds to. Frontend ARR rules proxy here.
BACKEND_PORT=5000

# Azure OpenAI — these end up in the backend Web.config <environmentVariables>.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.us/
AZURE_OPENAI_API_KEY=replace-me
AZURE_OPENAI_DEPLOYMENT=gpt-4

# Optional. Leave blank if the backend runs without a DB.
DATABASE_URL=

# Path to the unzipped build artifact (frontend/, backend/, wheelhouse/,
# web.config.*.tpl, deploy-prod.ps1). If you're running deploy-prod.ps1 from
# inside the unzipped package, you can leave this blank -- it defaults to the
# script's own directory.
PACKAGE_ROOT=

# Optional. By default deploy-prod.ps1 stops the IIS Default Web Site so it
# cannot intercept requests to http://<SITE_HOSTNAME>/ via its *:80: catch-all
# binding (it would otherwise serve the IIS welcome page instead of letting
# our :80 redirect rule fire). On a shared server where Default Web Site is
# genuinely in use, set this to 1 to leave it running.
KEEP_DEFAULT_SITE=
